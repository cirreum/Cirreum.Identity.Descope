<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<RootNamespace>Cirreum.Identity.Descope</RootNamespace>
		<Description>Descope integration for user provisioning during sign-in. Hosts the HTTP endpoint called from a Descope Flow's HTTP Connector, validates the inbound request, provisions the user via IUserProvisioner, and returns roles to embed in the issued JWT.</Description>
		<PackageTags>cirreum;descope;identity;provisioning;minimal-api;ciam</PackageTags>
	</PropertyGroup>

	<ItemGroup>
		<FrameworkReference Include="Microsoft.AspNetCore.App" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.IdentityModel.Protocols.OpenIdConnect" Version="8.17.0" />
		<PackageReference Include="System.IdentityModel.Tokens.Jwt" Version="8.17.0" />
		<PackageReference Include="Cirreum.Identity.Abstractions" Version="1.0.0" />
	</ItemGroup>

</Project>
